# Garmin Connect credentials
# Your Garmin Connect username (email address)
GARMIN_USER=your_garmin_email@example.com

# Your Garmin Connect password
GARMIN_PASS=your_garmin_password

# Slack webhook URL for notifications (optional)
# Get this from your Slack workspace: Apps > Incoming Webhooks
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Example usage:
# 1. Copy this file to .env
# 2. Replace the example values with your actual credentials
# 3. Never commit the .env file to version control